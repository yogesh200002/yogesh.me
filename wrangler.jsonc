{
	"$schema": "./node_modules/wrangler/config-schema.json",
	"name": "portfolio-website",
	"compatibility_date": "2026-06-12",
	"compatibility_flags": ["nodejs_compat_v2"],
	"routes": [
		{
			"pattern": "yogesh.me",
			"custom_domain": true,
		},
	],
	"assets": {
		"directory": "./dist",
	},
	"observability": {
		"enabled": true,
	},
}
